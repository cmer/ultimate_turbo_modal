<% if flash.any? %>
  <div class="fixed top-4 right-4 z-50 flex flex-col gap-2" data-controller="flash">
    <% flash.each do |key, value| %>
      <div
        data-flash-target="toast"
        class="
          flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg backdrop-blur-sm
          transform transition-all duration-300 ease-out
          translate-x-[120%] opacity-0
          min-w-[280px] max-w-sm
          <%= key == 'alert' ?
            'bg-red-50/95 dark:bg-red-950/90 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-200' :
            'bg-emerald-50/95 dark:bg-emerald-950/90 border border-emerald-200 dark:border-emerald-800 text-emerald-800 dark:text-emerald-200'
          %>
        "
        role="<%= key == 'alert' ? 'alert' : 'status' %>"
      >
        <% if key == "alert" %>
          <svg class="w-5 h-5 shrink-0 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        <% else %>
          <svg class="w-5 h-5 shrink-0 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        <% end %>
        <span class="text-sm font-medium"><%= value %></span>
      </div>
    <% end %>
  </div>
<% end %>
