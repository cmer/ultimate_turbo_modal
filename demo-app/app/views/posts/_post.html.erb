<div id="<%= dom_id post %>" class="py-4 border-b border-gray-200 dark:border-gray-700">
  <div class="flex justify-between items-start">
    <div>
      <% if !inside_modal? %>
        <h3 class="text-lg font-semibold"><%= post.title %></h3>
      <% end %>
      <p class="my-2 text-gray-600 dark:text-gray-400">
        <%= post.body %>
      </p>
    </div>
    <% if !inside_modal? %>
      <%= link_to edit_post_path(post),
          data: { turbo_frame: "modal" },
          class: "rounded-lg py-2 px-4 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 text-sm font-medium transition-colors" do %>
        Edit
      <% end %>
    <% end %>
  </div>
</div>
