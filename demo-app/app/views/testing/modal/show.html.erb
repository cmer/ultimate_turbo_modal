<% modal_title = (params[:id] == "multi_page") ? "Multi-page wizard" : nil %>
<%= modal(padding: @padding, advance: @override_url || @advance, header: @header, close_button: @close_button, overlay: @overlay, title: modal_title) do %>
  <% unless inside_modal? %>
    <h1 class="text-2xl mb-8">This is not inside a modal</h1>
  <% end %>

  <% if params[:id] == "long" %>
    <div class="space-y-2 max-w-3xl">
      <% 30.times do %>
        <p><%= Faker::Lorem.paragraph(sentence_count: 50) %></p>
      <% end %>
    </div>
  <% elsif params[:id] == "photo" %>
    <div class="w-full">
      <img src="/img/unicat.jpg">
    </div>
  <% elsif params[:id] == "photo_no_advance" %>
    <div class="w-full">
      <img src="/img/unicat.jpg">
    </div>
  <% elsif params[:id] == "no_overlay" %>
    <div class="w-full">
      <p>This modal has no backdrop overlay. Click outside to dismiss.</p>
    </div>
  <% elsif params[:id] == "multi_page" %>
    <% step = (params[:step].presence || 1).to_i.clamp(1, 3) %>
    <div class="space-y-4 dark:text-white">
      <h2 class="text-xl font-semibold">Page <%= step %> of 3</h2>
      <p>
        <% case step %>
        <% when 1 %>
          Welcome! Click Next to navigate to page 2 inside this same modal —
          Turbo replaces the frame contents while the dialog stays open.
        <% when 2 %>
          You're now on page 2. The modal didn't close: only the frame's
          contents were swapped via Idiomorph.
        <% when 3 %>
          Final page. You can go back to the previous page or close the modal.
        <% end %>
      </p>

      <div class="flex items-center justify-between pt-4 border-t border-gray-200 dark:border-gray-700">
        <% if step > 1 %>
          <%= link_to "← Previous",
                testing_modal_path(:multi_page, step: step - 1, advance: params[:advance], close_button: params[:close_button]),
                class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-gray-700 dark:text-white dark:ring-gray-600 dark:hover:bg-gray-600" %>
        <% else %>
          <span></span>
        <% end %>

        <% if step < 3 %>
          <%= link_to "Next →",
                testing_modal_path(:multi_page, step: step + 1, advance: params[:advance], close_button: params[:close_button]),
                class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
        <% else %>
          <button type="button" data-action="modal#hideModal" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500">Done</button>
        <% end %>
      </div>
    </div>
  <% elsif params[:id] == "form" %>
    <div class="w-full p-4">
      <form>
        <div class="mb-4">
          <label class="block mb-2" for="fname">First Name:</label>
          <input class="rounded border-gray-300 border" type="text" id="fname" name="fname" autofocus>
        </div>
        <div class="mb-4">
          <label class="block mb-2" for="lname">Last Name:</label>
          <input class="rounded border-gray-300 border" type="text" id="lname" name="lname">
        </div>
        <button class="rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" type="submit">Submit</button>
      </form>
    </div>
  <% else %>
    <div class="w-full">
      Not sure what you're looking for!
    </div>
  <% end %>
<% end %>
