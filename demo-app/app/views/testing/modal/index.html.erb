<%= render partial: "testing/hide_from_backends/notice" %>
<div class="fixed left-3 bottom-3 text-lg text-gray-600">
  Rendered at <%= Time.now %>
</div>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <!-- We've used 3xl here, but feel free to try other max-widths based on your needs -->
  <div class="mx-auto max-w-3xl space-y-24">
    <div>
      <h1 class="<%= h1_classes %>">CRUD modals</h1>
      <ul class="list-disc ml-6 dark:text-white">
        <li class="py-2"><%= link_to "Show Post", testing_post_path(@post, close_button: 1), data: {turbo_frame: "modal"} %>
        <li class="py-2"><%= link_to "New Post", new_testing_post_path(Post.new, close_button: 1), data: {turbo_frame: "modal"} %>
        <li class="py-2"><%= link_to "Show Post (w/ advance history)", testing_post_path(@post, advance: "1", close_button: 1), data: {turbo_frame: "modal"} %>
      </ul>
    </div>

    <div>
      <h1 class="<%= h1_classes %>">More modals</h1>
      <ul class="list-disc ml-6 dark:text-white">
        <li class="py-2">Photo: <%= link_to "without header or padding", testing_modal_path(:photo, padding: 0, advance: 1, close_button: 1), data: {turbo_frame: "modal"} %> | <%= link_to "without close button", testing_modal_path(:photo, padding: 0, advance: 1, close_button: 0), data: {turbo_frame: "modal"} %>
        <li class="py-2"><%= link_to "Long scrolling content", testing_modal_path(:long, advance: 1, close_button: 1), data: {turbo_frame: "modal"} %>
        <li class="py-2"><%= link_to "Form closing from backend on success", new_testing_hide_from_backend_path(close_button: 1), data: {turbo_frame: "modal"} %>
      </ul>
    </div>

    <div>
      <h1 class="<%= h1_classes %>">Drawers</h1>
      <ul class="list-disc ml-6 dark:text-white">
        <li class="py-2"><%= link_to "Drawer demos →", testing_drawers_path %>
      </ul>
    </div>
  </div>
</div>


<div class="mx-auto text-center">
  <% 30.times do %>
    <div class="my-48 text-gray-300 mx-auto">
      This is a long page!
    </div>
  <% end %>

  <div>
    <input type="text" class="rounded border-gray-300 placeholder-gray-300" placeholder="Test for focus trap" />
  </div>
</div>

<div class="my-20 text-center">
  <%= link_to "Click for a unicat", testing_modal_path(:photo, padding: 0, advance: 1), class: button_classes, data: {turbo_frame: "modal"} %>
</div>
