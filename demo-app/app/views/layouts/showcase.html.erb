<!DOCTYPE html>
<html class="<%= cookies[:theme] == "dark" ? "dark" : "" %>">
  <head>
    <title>Ultimate Turbo Modal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800 dark:text-white min-h-screen transition-colors">
    <%= turbo_frame_tag "modal" %>
    <%= render partial: "shared/flash" %>

    <nav class="fixed top-0 right-0 z-40 flex items-center gap-3 px-5 py-3">
      <%# Flavor toggle %>
      <div class="flex items-center rounded-full bg-white/80 dark:bg-slate-700/80 backdrop-blur shadow-sm border border-slate-200 dark:border-slate-600 text-sm font-medium">
        <% tw_active = UltimateTurboModal.flavor == :tailwind %>
        <%= link_to "Tailwind",
            url_for(request.query_parameters.merge(flavor: "tailwind")),
            class: "px-3 py-1.5 rounded-full transition-colors #{tw_active ? 'bg-sky-500 text-white shadow' : 'text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white'}" %>
        <%= link_to "Vanilla",
            url_for(request.query_parameters.merge(flavor: "vanilla")),
            class: "px-3 py-1.5 rounded-full transition-colors #{!tw_active ? 'bg-amber-500 text-white shadow' : 'text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white'}" %>
      </div>

      <%# Dark mode toggle %>
      <div class="text-slate-600 dark:text-slate-300" data-controller="dark-mode">
        <button data-action="click->dark-mode#toggleTheme" class="p-2 rounded-full bg-white/80 dark:bg-slate-700/80 backdrop-blur shadow-sm border border-slate-200 dark:border-slate-600 hover:bg-white dark:hover:bg-slate-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 dark:hidden">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 hidden dark:block">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
        </button>
      </div>
    </nav>

    <%= yield %>
  </body>
</html>
